def get_route_geometry(start_coords, end_coords):
    url = f"http://router.project-osrm.org/route/v1/driving/{start_coords[1]},{start_coords[0]};{end_coords[1]},{end_coords[0]}?overview=full"
    try:
        response = requests.get(url, timeout=2)
        if response.status_code == 200:
            data = response.json()
            poly_str = data['routes'][0]['geometry']
            return polyline.decode(poly_str)
    except Exception:
        pass
    return [start_coords, end_coords]

def get_mode_factor(mode):
    return {"Low": 0.8, "Medium": 1.0, "High": 1.6}[mode]

def get_road_penalty(traffic):
    return {"Low": 0.0, "Medium": 1.0, "High": 2.0}[traffic]

def build_weighted_graph(traffic_level, sensitivity):
    G = copy.deepcopy(base_G)
    for u, v, d in G.edges(data=True):
        base = d["weight"]
        traffic = traffic_data.get((u, v)) or traffic_data.get((v, u)) or "Low"
        penalty = get_road_penalty(traffic)
        factor = get_mode_factor(traffic_level)
        d["weight"] = base + base * penalty * factor * sensitivity
    return G

def heuristic(n1, n2):
    x1, y1 = locations[n1]
    x2, y2 = locations[n2]
    return math.sqrt((x1 - x2)**2 + (y1 - y2)**2)

def route_cost(G, path):
    return sum(G[u][v]["weight"] for u, v in zip(path, path[1:]))

def dijkstra_search(G, source, destination):
    visited = set()
    queue = [(0.0, source, [source])]
    nodes_explored = 0
    while queue:
        cost, node, path = heapq.heappop(queue)
        if node == destination:
            return path, nodes_explored
        if node in visited: continue
        visited.add(node)
        nodes_explored += 1
        for nbr in G.neighbors(node):
            if nbr not in visited:
                heapq.heappush(queue, (cost + G[node][nbr]["weight"], nbr, path + [nbr]))
    raise nx.NetworkXNoPath(f"No path found from {source} to {destination}")

def astar_search(G, source, destination):
    visited = set()
    queue = [(heuristic(source, destination), 0.0, source, [source])]
    nodes_explored = 0
    while queue:
        _, cost, node, path = heapq.heappop(queue)
        if node == destination:
            return path, nodes_explored
        if node in visited: continue
        visited.add(node)
        nodes_explored += 1
        for nbr in G.neighbors(node):
            if nbr not in visited:
                new_cost = cost + G[node][nbr]["weight"]
                heapq.heappush(queue, (new_cost + heuristic(nbr, destination), new_cost, nbr, path + [nbr]))
    raise nx.NetworkXNoPath(f"No path found from {source} to {destination}")

def greedy_best_first_search(G, source, destination):
    """Greedy Best-First Search: Weight-aware and heuristic-guided"""
    visited = set()
    heap = [(heuristic(source, destination), 0.0, source, [source])]
    nodes_explored = 0
    
    while heap:
        _, cost_so_far, node, path = heapq.heappop(heap)
        
        if node == destination:
            return path, nodes_explored
        if node in visited: continue
        visited.add(node)
        nodes_explored += 1
        
        for nbr in G.neighbors(node):
            if nbr not in visited:
                edge_cost = G[node][nbr]["weight"]
                new_cost = cost_so_far + edge_cost
                h_value = heuristic(nbr, destination)
                priority = 0.6 * h_value + 0.4 * new_cost
                heapq.heappush(heap, (priority, new_cost, nbr, path + [nbr]))
    
    raise nx.NetworkXNoPath(f"No path found from {source} to {destination}")

def true_ao_star_search(G, source, destination):
    """True AO* Implementation: Models the problem as AND-OR graph subgoals."""
    queue = [(heuristic(source, destination), 0.0, source, [source])]
    best_cost = {source: 0.0}
    nodes_explored = 0
    
    while queue:
        _, cost_so_far, node, path = heapq.heappop(queue)
        nodes_explored += 1
        
        if node == destination:
            return path, nodes_explored
        if cost_so_far > best_cost.get(node, float("inf")): continue
            
        # OR branches
        for nbr in G.neighbors(node):
            if nbr in path: continue
            
            # AND evaluation: evaluate multiple constraints implicitly
            base_dist = G[node][nbr]["weight"]
            new_cost = cost_so_far + base_dist
            
            if new_cost < best_cost.get(nbr, float("inf")):
                best_cost[nbr] = new_cost
                priority = new_cost + heuristic(nbr, destination)
                heapq.heappush(queue, (priority, new_cost, nbr, path + [nbr]))
                
    raise nx.NetworkXNoPath(f"No path found from {source} to {destination}")

def solve_route(G, source, destination, algorithm):
    start_time = time.perf_counter()
    if "Dijkstra" in algorithm:
        path, nodes_ex = dijkstra_search(G, source, destination)
    elif "A*" in algorithm and "AO*" not in algorithm:
        path, nodes_ex = astar_search(G, source, destination)
    elif "Greedy" in algorithm:
        path, nodes_ex = greedy_best_first_search(G, source, destination)
    elif "AO*" in algorithm:
        path, nodes_ex = true_ao_star_search(G, source, destination)
    else:
        raise ValueError(f"Unsupported algorithm: {algorithm}")
        
    exec_time = (time.perf_counter() - start_time) * 1000
    cost = route_cost(G, path)
    return path, cost, nodes_ex, exec_time

def solve_multi_stop_route(G, source, destination, waypoints, algorithm):
    # Nearest Neighbor TSP
    full_path, total_cost, total_nodes, total_time = [], 0.0, 0, 0.0
    current = source
    unvisited = waypoints.copy()
    
    while unvisited:
        best_leg_cost = float("inf")
        best_leg = None
        for wp in unvisited:
            p, c, n, t = solve_route(G, current, wp, algorithm)
            if c < best_leg_cost:
                best_leg_cost, best_leg = c, (p, c, n, t, wp)
                
        p, c, n, t, wp = best_leg
        if full_path: full_path.extend(p[1:])
        else: full_path.extend(p)
        total_cost += c
        total_nodes += n
        total_time += t
        current = wp
        unvisited.remove(wp)
        
    # Final leg
    p, c, n, t = solve_route(G, current, destination, algorithm)
    if full_path: full_path.extend(p[1:])
    else: full_path.extend(p)
    total_cost += c
    total_nodes += n
    total_time += t
    
    return full_path, total_cost, total_nodes, total_time

